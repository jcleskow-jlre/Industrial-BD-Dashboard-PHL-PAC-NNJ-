function show(id){document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));byId(id).classList.add('active');document.querySelectorAll('.nav button').forEach((b,i)=>b.classList.toggle('active',tabs[i][0]===id)); if(id==='map'&&!window.mapReady)setTimeout(initMap,100)}
function metric(label,value,sub,w){return `<div class="card metric"><div class="label">${label}</div><div class="value">${value}</div><div class="sub">${sub||''}</div><div class="spark"><span style="width:${w||72}%"></span></div></div>`}
function barChart(items,val,label,kind='auto'){let max=Math.max(...items.map(x=>x[val]||0),1);return `<div class="chart">${items.map(x=>{let isMoney = kind==='money' || (kind==='auto' && (val.toLowerCase().includes('rent')||val.toLowerCase().includes('ner')));let display = isMoney?money(x[val]):pct(x[val]);return `<div class="bar" style="height:${Math.max(4,(x[val]||0)/max*100)}%"><em>${display}</em><small>${x[label]}</small></div>`}).join('')}</div>`}
function table(rows, cols, limit=250){currentRows=rows; currentHeaders=cols; return `<div class="tableWrap"><table><thead><tr>${cols.map(c=>`<th onclick="sortTable('${c.key}')">${c.label}</th>`).join('')}</tr></thead><tbody id="tbody">${rows.slice(0,limit).map(r=>rowHtml(r,cols)).join('')}</tbody></table>${rows.length>limit?`<p class="searchNote">Showing first ${limit.toLocaleString()} of ${rows.length.toLocaleString()} filtered rows.</p>`:''}</div>`}
function rowHtml(r,cols){return `<tr>${cols.map(c=>`<td class="${c.num?'num':''}">${c.render?c.render(r):(r[c.key]??'')}</td>`).join('')}</tr>`}
function sortTable(key){currentRows.sort((a,b)=>{let x=valueForKey(a,key),y=valueForKey(b,key); if(typeof x==='number'||typeof y==='number'||(!isNaN(Number(x))&&!isNaN(Number(y)))) return Number(y||0)-Number(x||0); return String(y||'').localeCompare(String(x||''));}); byId('tbody').innerHTML=currentRows.slice(0,250).map(r=>rowHtml(r,currentHeaders)).join('')}
function textFilter(rows,q){q=(q||'').toLowerCase(); if(!q)return rows; return rows.filter(r=>Object.values(r).join(' ').toLowerCase().includes(q))}
function unique(arr,k){return [...new Set(arr.map(x=>x[k]).filter(Boolean))].sort()}
function selectOpts(vals){return `<option value="">All</option>`+vals.map(v=>`<option>${v}</option>`).join('')}
function parseDate(v){if(!v)return null; let d=new Date(v+'T00:00:00'); return isNaN(d)?null:d;}
function yearsElapsed(start,end){if(!start||!end)return 0; return Math.max(0,(end-start)/millisPerYear);}
function calcCurrentRent(r){let base=Number(r.startingRent); if(!base||isNaN(base))return null; let start=parseDate(r.commenced); let expire=parseDate(r.expires); let effective=today; if(expire&&expire<effective) effective=expire; if(start&&start>effective) return base; let fullYears=start?Math.floor(yearsElapsed(start,effective)+1e-8):0; let escText=(r.escalation||'').toString(); let raw=r.escalationRaw; if(!escText||fullYears<=0) return base; if(escText.includes('%') || (raw!=null && raw>0 && raw<1)){let rate=raw!=null?Number(raw):Number(escText.replace(/[^\d.\-]/g,''))/100; if(isNaN(rate)) return base; return base*Math.pow(1+rate,fullYears);} if(escText.includes('$') || (raw!=null && raw>=1)){let bump=raw!=null?Number(raw):Number(escText.replace(/[^\d.\-]/g,'')); if(isNaN(bump)) return base; return base + (bump*fullYears);} return base;}
function calcMarketDeltaPct(r){let current=calcCurrentRent(r), market=Number(r.marketRent); if(!current||!market||isNaN(current)||isNaN(market)||market===0) return null; return ((current/market)-1)*100;}
function renderMarketDelta(delta){if(delta==null||isNaN(delta)) return ''; let cls=delta>=0?'deltaPos':'deltaNeg'; let word=delta>=0?'above':'below'; return `<span class="${cls}">${Math.abs(delta).toFixed(1)}% ${word}</span>`;}
function termYears(r){let c=parseDate(r.commenced), e=parseDate(r.expires); if(!c||!e) return null; let years=yearsElapsed(c,e); return years>0?years:null;}
function freeRentPSFPerYear(r){let term=termYears(r); let rent=Number(r.startingRent); let months=Number(r.freeMonths||0); if(!term||!rent||!months) return 0; return ((rent/12)*months)/term;}
function tiPSFPerYear(r){let term=termYears(r); let ti=Number(r.ti||0); if(!term||!ti) return 0; return ti/term;}
function totalConcPSFPerYear(r){return freeRentPSFPerYear(r)+tiPSFPerYear(r)}
const PHL_PA_SUBS = new Set(['Bucks County','Chester County','Delaware County','Montgomery County','Philadelphia County','Outer Philadelphia County','Outer Philadelphia','Horsham','Berks County','Parkway Corridor','Business Park']);
const SNJ_SUBS = new Set(['Burlington County','Camden County','Gloucester County','Salem County','Cumberland County']);
function inferMarket(r){if(r.region==='NNJ') return 'Northern New Jersey'; if(r.region==='PA I-81/78') return 'PA I-81/78 Corridor'; if(r.region==='Philadelphia' || r.region==='Philly / SNJ' || r.region==='Northern DE') return 'Philadelphia'; if(r.state==='DE') return 'Philadelphia'; if(r.state==='NJ') return SNJ_SUBS.has(r.submarket)?'Philadelphia':'Northern New Jersey'; if(r.state==='PA') return PHL_PA_SUBS.has(r.submarket)?'Philadelphia':'PA I-81/78 Corridor'; return 'Unassigned';}
function getWindowComps(months=18){let start=new Date(today); start.setMonth(start.getMonth()-months); return DATA.comps.filter(c=>{let d=parseDate(c.commenced); return d && d<=today && d>=start;})}
function avg(arr,fn){let vals=arr.map(fn).filter(v=>v!=null && v!=='' && !isNaN(v)); if(!vals.length) return null; return vals.reduce((a,b)=>a+Number(b),0)/vals.length;}
function quarterLabel(d){let q=Math.floor(d.getMonth()/3)+1; return `Q${q} ${d.getFullYear()}`;}
function sortQuarterLabels(labels){return labels.sort((a,b)=>{let [qa,ya]=a.split(' '), [qb,yb]=b.split(' '); return (Number(ya)*4+Number(qa.slice(1))) - (Number(yb)*4+Number(qb.slice(1)));})}
function marketCompSummary(market){let rows=getWindowComps().filter(c=>inferMarket(c)===market); let typeCounts = rows.reduce((acc,r)=>{let k=r.leaseType||'Unknown'; acc[k]=(acc[k]||0)+1; return acc;},{}); return {market,rows,count:rows.length,avgStart:avg(rows,r=>r.startingRent),avgCurrent:avg(rows,r=>calcCurrentRent(r)),avgNER:avg(rows,r=>r.ner),avgFreeYr:avg(rows,r=>freeRentPSFPerYear(r)),avgTiYr:avg(rows,r=>tiPSFPerYear(r)),avgConcYr:avg(rows,r=>totalConcPSFPerYear(r)),avgTerm:avg(rows,r=>termYears(r)),avgSf:avg(rows,r=>r.sf),renewals:typeCounts['Renewal']||0,newLeases:typeCounts['New Lease']||0,expansions:typeCounts['Expansion']||0};}
function marketTrend(market){let rows=getWindowComps().filter(c=>inferMarket(c)===market); let buckets={}; rows.forEach(r=>{let d=parseDate(r.commenced); if(!d) return; let key=quarterLabel(d); (buckets[key] ||= []).push(r);}); let labels = sortQuarterLabels(Object.keys(buckets)); return labels.map(label=>{let list=buckets[label]; return {quarter:label,count:list.length,avgStart:avg(list,r=>r.startingRent),avgNER:avg(list,r=>r.ner),avgFreeYr:avg(list,r=>freeRentPSFPerYear(r)),avgTiYr:avg(list,r=>tiPSFPerYear(r)),avgConcYr:avg(list,r=>totalConcPSFPerYear(r))};})}
function trendTableHtml(market){let rows=marketTrend(market); if(!rows.length) return `<p class="searchNote">No commenced comps fell in the last 18 months for this market based on the uploaded data.</p>`; return `<div class="trendWrap"><h4 style="margin:0 0 8px">Quarterly 18-month trend</h4><table class="trendTable"><thead><tr><th>Quarter</th><th>Count</th><th>Avg start</th><th>Avg NER</th><th>Free PSF/Yr</th><th>TI PSF/Yr</th><th>Total conc./Yr</th></tr></thead><tbody>${rows.map(r=>`<tr><td>${r.quarter}</td><td>${r.count}</td><td>${money(r.avgStart)}</td><td>${money(r.avgNER)}</td><td>${money(r.avgFreeYr)}</td><td>${money(r.avgTiYr)}</td><td>${money(r.avgConcYr)}</td></tr>`).join('')}</tbody></table></div>`;}
function openReport(market){let rep=REPORTS[market]; if(!rep) return; byId('reportModalTitle').textContent=`${market} | Savills Research report`; byId('reportFrame').src=rep.path+'#view=FitH'; let a=byId('reportNewTab'); a.onclick=()=>window.open(rep.path,'_blank'); byId('reportModal').classList.add('show');}
function closeReport(){byId('reportModal').classList.remove('show'); byId('reportFrame').src='';}
byId('reportModal').addEventListener('click', e=>{if(e.target===byId('reportModal')) closeReport();});
function renderOverview(){let s=DATA.summary; let leaseRows = DATA.bd.slice().sort((a,b)=>((a.monthsToExpire??999)-(b.monthsToExpire??999)) || ((b.sf||0)-(a.sf||0))).slice(0,8); let topAvail=DATA.availabilities.slice().sort((a,b)=>b.availableSf-a.availableSf).slice(0,5);byId('overview').innerHTML=`
<div class="grid4">${metric('Lease Events',s.bdCount.toLocaleString(),'tracked events / targets',82)}${metric('Total Inventory',s.inventoryMsf+' MSF',s.buildingCount.toLocaleString()+' buildings 150K+ SF',94)}${metric('Comps in Database',s.compCount.toLocaleString(),'Avg rent '+money(s.compRentAvg)+' · Avg NER '+money(s.nerAvg),72)}${metric('Active Availability',s.availableMsf+' MSF',s.availCount.toLocaleString()+' available buildings/spaces',68)}</div>
<div class="layout"><div class="card"><h3 class="sectionTitle">Market rent pulse</h3>${barChart(DATA.marketStats,'askingRent','region','money')}<div class="insight">Northern New Jersey still carries the highest average asking rent. Philadelphia remains the highest-vacancy major market. PA I-81/78 continues to be the cost-efficiency alternative with materially lower face rents.</div></div><div class="card"><h3 class="sectionTitle">Near-term lease events</h3><div class="cardsList">${leaseRows.map(x=>`<div class="miniCard"><div class="row"><h4>${x.tenant}</h4><span class="badge">${x.monthsToExpire} mo.</span></div><p>${x.address}, ${x.state} · ${fmtSF(x.sf)} SF · expires ${x.expires||'N/A'} · current ${money(calcCurrentRent(x))} vs market ${money(x.marketRent)} · ${renderMarketDelta(calcMarketDeltaPct(x))}</p></div>`).join('')}</div></div></div>
<div class="layout"><div class="card"><h3 class="sectionTitle">Largest active availabilities</h3>${table(topAvail,[{key:'name',label:'Property'},{key:'city',label:'City'},{key:'state',label:'ST'},{key:'availableSf',label:'Available SF',num:true,render:r=>fmtSF(r.availableSf)},{key:'rent',label:'Rent',num:true,render:r=>money(r.rent)},{key:'owner',label:'Owner'}],20)}</div><div class="card"><h3 class="sectionTitle">Fresh-build notes</h3><div class="insight">This refreshed build now shifts the BD section into a cleaner <b>Lease Events</b> view, adds calculated <b>Current Rent</b>, shows each tenant’s current position <b>above or below market</b>, and expands Market AI with embedded Savills Research report viewing plus 18-month apples-to-apples concession analytics.</div><div class="kvs"><div class="kv"><b>${DATA.comps.filter(c=>c.matchConfidence>0).length.toLocaleString()}</b><span>Comps matched to buildings</span></div><div class="kv"><b>${DATA.comps.filter(c=>!c.ner).length.toLocaleString()}</b><span>Comps missing NER</span></div><div class="kv"><b>${DATA.buildings.filter(b=>b.lat&&b.lng).length.toLocaleString()}</b><span>Mapped buildings</span></div><div class="kv"><b>${getWindowComps().length.toLocaleString()}</b><span>Comps in last 18 months</span></div></div></div></div>`}
function renderComps(){let states=unique(DATA.comps,'state'), types=unique(DATA.comps,'leaseType'); byId('comps').innerHTML=`<div class="card"><h3 class="sectionTitle">Comp Database</h3><div class="filters"><input id="compQ" placeholder="Search tenant, address, submarket..." oninput="filterComps()"><select id="compState" onchange="filterComps()">${selectOpts(states)}</select><select id="compType" onchange="filterComps()">${selectOpts(types)}</select></div><div id="compTable"></div></div>`; filterComps()}
function filterComps(){let q=byId('compQ')?.value||'', st=byId('compState')?.value||'', ty=byId('compType')?.value||''; let rows=DATA.comps.filter(x=>(!st||x.state===st)&&(!ty||x.leaseType===ty)); rows=textFilter(rows,q).sort((a,b)=>String(b.commenced||'').localeCompare(String(a.commenced||''))); let cols=[{key:'tenant',label:'Tenant Name'},{key:'address',label:'Street Address'},{key:'city',label:'City'},{key:'state',label:'State'},{key:'submarket',label:'Submarket'},{key:'leaseType',label:'Lease Type'},{key:'sf',label:'Square Feet',num:true,render:r=>fmtSF(r.sf)},{key:'commenced',label:'Commenced'},{key:'expires',label:'Expires'},{key:'startingRent',label:'Starting Rent',num:true,render:r=>money(r.startingRent)},{key:'escalation',label:'Annual Esc.'},{key:'freeRent',label:'Free Rent'},{key:'ti',label:'TI/PSF',num:true,render:r=>money(r.ti)},{key:'ner',label:'NER',num:true,render:r=>money(r.ner)}]; byId('compTable').innerHTML=table(rows,cols)}
function renderAvail(){let states=unique(DATA.availabilities,'state');byId('avail').innerHTML=`<div class="card"><h3 class="sectionTitle">Active Availability Database</h3><div class="filters"><input id="availQ" placeholder="Search availability..." oninput="filterAvail()"><select id="availState" onchange="filterAvail()">${selectOpts(states)}</select></div><div id="availTable"></div></div>`;filterAvail()}
function filterAvail(){let q=byId('availQ')?.value||'', st=byId('availState')?.value||'';let rows=DATA.availabilities.filter(x=>(!st||x.state===st));rows=textFilter(rows,q).sort((a,b)=>b.availableSf-a.availableSf);let cols=[{key:'name',label:'Property'},{key:'address',label:'Address'},{key:'city',label:'City'},{key:'state',label:'State'},{key:'submarket',label:'Submarket'},{key:'availableSf',label:'Available SF',num:true,render:r=>fmtSF(r.availableSf)},{key:'rent',label:'Rent',num:true,render:r=>money(r.rent)},{key:'clearHeight',label:'Clear'},{key:'owner',label:'Owner'}];byId('availTable').innerHTML=table(rows,cols)}
function renderLeaseEvents(){let states=unique(DATA.bd,'state'); let markets=['Northern New Jersey','Philadelphia','PA I-81/78 Corridor']; byId('lease').innerHTML=`<div class="layout"><div class="card"><h3 class="sectionTitle">Lease Events</h3><div class="filters"><input id="leaseQ" placeholder="Search tenants or addresses..." oninput="filterLeaseEvents()"><select id="leaseState" onchange="filterLeaseEvents()">${selectOpts(states)}</select><select id="leaseMarket" onchange="filterLeaseEvents()">${selectOpts(markets)}</select></div><div id="leaseTable"></div></div><div class="card"><h3 class="sectionTitle">Tenant-rep angle</h3><div id="leaseCards" class="cardsList"></div></div></div>`;filterLeaseEvents()}
function filterLeaseEvents(){let q=byId('leaseQ')?.value||'', st=byId('leaseState')?.value||'', mk=byId('leaseMarket')?.value||'';let rows=DATA.bd.filter(x=>(!st||x.state===st)&&(!mk||inferMarket(x)===mk));rows=textFilter(rows,q).sort((a,b)=>((a.monthsToExpire??999)-(b.monthsToExpire??999)) || ((b.sf||0)-(a.sf||0)));let cols=[{key:'tenant',label:'Tenant'},{key:'address',label:'Address'},{key:'state',label:'ST'},{key:'sf',label:'SF',num:true,render:r=>fmtSF(r.sf)},{key:'commenced',label:'Commenced'},{key:'expires',label:'Expires'},{key:'monthsToExpire',label:'Months',num:true},{key:'startingRent',label:'Starting Rent',num:true,render:r=>money(r.startingRent)},{key:'currentRentCalc',label:'Current Rent',num:true,render:r=>money(calcCurrentRent(r))},{key:'marketDeltaPct',label:'% vs Mkt',render:r=>renderMarketDelta(calcMarketDeltaPct(r))},{key:'marketRent',label:'Market Rent',num:true,render:r=>money(r.marketRent)}];byId('leaseTable').innerHTML=table(rows,cols);byId('leaseCards').innerHTML=rows.slice(0,16).map(r=>`<div class="miniCard"><h4>${r.tenant}</h4><p>${r.angle}. ${r.monthsToExpire} months to expiration, ${fmtSF(r.sf)} SF, ${r.submarket||'submarket not specified'}. Current rent ${money(calcCurrentRent(r))} vs market ${money(r.marketRent)} · ${renderMarketDelta(calcMarketDeltaPct(r))}.</p></div>`).join('')}
function renderAI(){
  const markets = ['Northern New Jersey','Philadelphia','PA I-81/78 Corridor'];
  const reportCards = DATA.marketStats.map(m=>`<div class="card"><div class="row"><h3>${m.market}</h3><span class="pillStat"><b>${REPORTS[m.market].short}</b></span></div><div class="kvs"><div class="kv"><b>${m.inventoryMsf} MSF</b><span>Inventory</span></div><div class="kv"><b>${pct(m.vacancy)}</b><span>Vacancy</span></div><div class="kv"><b>${money(m.askingRent)}</b><span>Asking rent</span></div><div class="kv"><b>${m.underConstructionMsf} MSF</b><span>Under construction</span></div></div><p>${m.outlook}</p><div class="reportButtons"><button class="btn small" onclick="openReport('${m.market}')">Enlarge report</button><button class="btn secondary small" onclick="window.open(REPORTS['${m.market}'].path,'_blank')">Open PDF</button></div><div class="viewerHelp">Use the enlarged viewer for the full Savills Research PDF.</div></div>`).join('');
  const breakdowns = markets.map(m=>{let s=marketCompSummary(m); return `<div class="card"><div class="row"><h3>${m}</h3><span class="pillStat"><b>${s.count}</b> comps / 18 mo.</span></div><p class="subtle">Face rent, current rent, NER, and concessions are normalized so you can compare markets more cleanly.</p><div class="kvs"><div class="kv"><b>${money(s.avgStart)}</b><span>Avg starting rent</span></div><div class="kv"><b>${money(s.avgCurrent)}</b><span>Avg current rent</span></div><div class="kv"><b>${money(s.avgNER)}</b><span>Avg NER</span></div><div class="kv"><b>${money(s.avgFreeYr)}</b><span>Free rent PSF / yr</span></div><div class="kv"><b>${money(s.avgTiYr)}</b><span>TI PSF / yr</span></div><div class="kv"><b>${money(s.avgConcYr)}</b><span>Total concessions / yr</span></div><div class="kv"><b>${(s.avgTerm||0).toFixed(1)}</b><span>Avg lease term (yrs)</span></div><div class="kv"><b>${fmtSF(Math.round(s.avgSf||0))}</b><span>Avg comp size</span></div></div><div class="pillRow"><span class="pillStat"><b>${s.newLeases}</b> new leases</span><span class="pillStat"><b>${s.renewals}</b> renewals</span><span class="pillStat"><b>${s.expansions}</b> expansions</span></div>${trendTableHtml(m)}</div>`;}).join('');
  const concChartItems = markets.map(m=>{let s=marketCompSummary(m); return {submarket:m, concYr:s.avgConcYr||0};});
  const nerChartItems = markets.map(m=>{let s=marketCompSummary(m); return {submarket:m, avgNER:s.avgNER||0};});
  byId('ai').innerHTML=`<div class="card"><h3 class="sectionTitle">Savills Research market reports</h3><p class="subtle">The three uploaded market PDFs are built directly into this section so they can be opened and enlarged for review.</p><div class="reportGrid">${reportCards}</div></div><div class="layout"><div class="card"><h3 class="sectionTitle">18-month avg total concessions / year</h3>${barChart(concChartItems,'concYr','submarket')}<div class="insight">Concessions are normalized into PSF per year to make long and short terms more comparable. This is the cleanest way to compare free rent and TI across markets.</div></div><div class="card"><h3 class="sectionTitle">18-month avg NER by market</h3>${barChart(nerChartItems,'avgNER','submarket')}<div class="insight">Use NER and normalized concession trends together. Face rent alone can overstate true economics where free rent and TI are meaningful.</div></div></div><div class="card" style="margin-top:14px"><h3 class="sectionTitle">Detailed comp breakdown | last 18 months</h3><p class="subtle">Below is a market-by-market breakdown of recent comp economics, including free rent and TI converted into PSF per year. The quarterly tables help show whether concessions are widening or compressing.</p><div class="marketBreakdowns">${breakdowns}</div></div>`;
}
function renderQA(){let s=DATA.summary;let missingCity=DATA.comps.filter(c=>!c.city).length;let unmatched=DATA.comps.filter(c=>!c.matchedBuildingId).length;let missingNer=DATA.comps.filter(c=>!c.ner).length;let missingRent=DATA.comps.filter(c=>!c.startingRent).length;byId('qa').innerHTML=`<div class="grid4">${metric('Missing Rent',missingRent,'should be zero',5)}${metric('Missing NER',missingNer,'records need economics review',20)}${metric('Unmatched Comps',unmatched,'not forced to weak building match',45)}${metric('Missing City',missingCity,'source did not include city',30)}</div><div class="card" style="margin-top:14px"><h3 class="sectionTitle">QA Review</h3><div class="insight">The consolidated comp file appears clean on core economics: starting rent is populated for all ${s.compCount.toLocaleString()} comps, and NER is available or calculated for nearly all records. Some records lack city/state or do not confidently match the 150K+ building inventory, so the app keeps those comps in the database but does not force building-level map placement.</div></div>`}
let map, buildingLayer, compLayer, availLayer;
function initMap(){window.mapReady=true;byId('map').innerHTML=`<div class="mapWrap"><div id="leaflet" class="map"></div><div class="mapPanel"><h3>Market Map</h3><div class="filters"><select id="mapMode" onchange="drawMap()"><option value="buildings">Buildings</option><option value="comps">Matched Comps</option><option value="avails">Availabilities</option></select><select id="mapState" onchange="drawMap()">${selectOpts(['PA','NJ','DE'])}</select></div><p class="searchNote">Click a marker for building / deal details.</p></div><div id="profile" class="profile"></div></div>`;map=L.map('leaflet',{zoomControl:false}).setView([40.35,-75.15],8);L.control.zoom({position:'bottomleft'}).addTo(map);L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{maxZoom:18, attribution:'© OpenStreetMap'}).addTo(map);drawMap()}
function markerHtml(color){return L.divIcon({className:'',html:`<div style="width:13px;height:13px;border-radius:50%;background:${color};border:2px solid white;box-shadow:0 0 0 5px rgba(255,223,0,.12)"></div>`,iconSize:[13,13]})}
function drawMap(){if(!map)return;[buildingLayer,compLayer,availLayer].forEach(l=>l&&map.removeLayer(l));let mode=byId('mapMode').value, st=byId('mapState').value;let pts=[];let color= mode==='buildings'?'#ffdf00':mode==='comps'?'#43d17f':'#61a5ff';let data=mode==='buildings'?DATA.buildings:mode==='comps'?DATA.comps:DATA.availabilities;data=data.filter(x=>x.lat&&x.lng&&(!st||x.state===st)).slice(0,3000);let group=L.layerGroup();data.forEach(x=>{let m=L.marker([x.lat,x.lng],{icon:markerHtml(color)}).on('click',()=>showProfile(x,mode));m.addTo(group);pts.push([x.lat,x.lng])});group.addTo(map);if(pts.length)map.fitBounds(pts,{padding:[30,30],maxZoom:10})}
function showProfile(x,mode){let p=byId('profile');p.classList.add('show');let current = mode==='comps'?calcCurrentRent(x):null; let delta = mode==='comps'?calcMarketDeltaPct(x):null; p.innerHTML=`<button class="close" onclick="byId('profile').classList.remove('show')">×</button><h2>${x.name||x.tenant||x.address}</h2><p>${x.address||''}${x.city?', '+x.city:''}${x.state?', '+x.state:''}</p><div class="kvs"><div class="kv"><b>${fmtSF(x.rba||x.sf||x.availableSf)}</b><span>${mode==='avails'?'Available/Building SF':'Square feet'}</span></div><div class="kv"><b>${money(x.marketRent||x.rent||x.startingRent)}</b><span>${mode==='buildings'?'Market rent':'Rent'}</span></div><div class="kv"><b>${pct(x.vacancy)}</b><span>Vacancy</span></div><div class="kv"><b>${x.submarket||x.region||''}</b><span>Submarket</span></div>${mode==='comps'?`<div class="kv"><b>${money(current)}</b><span>Current rent</span></div><div class="kv"><b>${renderMarketDelta(delta)}</b><span>Vs market</span></div>`:''}</div><div class="insight">${mode==='buildings'?'Building profile from master inventory. Use linked comps and nearby availability to evaluate tenant leverage.':mode==='comps'?'Matched comp / lease-event record. Compare starting rent, calculated current rent, NER, and normalized concessions against current market asking rent.':'Active availability from CoStar export. Use this as relocation leverage or competitive market pressure.'}</div>${x.maps?`<p><a style="color:var(--yellow)" href="${x.maps}" target="_blank">Open in Google Maps</a></p>`:''}`}
function downloadCSV(){let rows=currentRows||[]; if(!rows.length){alert('Open a table first.');return}let headers=currentHeaders.map(c=>c.label);let keys=currentHeaders.map(c=>c.key);let csv=[headers.join(',')].concat(rows.map(r=>keys.map(h=>`"${String(valueForKey(r,h)??'').replaceAll('\"','\"\"')}"`).join(','))).join(String.fromCharCode(10));let blob=new Blob([csv],{type:'text/csv'});let a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='dashboard_export.csv';a.click()}
renderOverview(); renderComps(); renderAvail(); renderLeaseEvents(); renderAI(); renderQA();
</script>
</body>
</html>