<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PHL-PAC-NNJ Industrial Market Intelligence & BD Dashboard</title>
  <link rel="preconnect" href="https://unpkg.com">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <style>
    :root{--yellow:#ffdf00;--navy:#25273A;--bg:#090b14;--panel:#10131f;--panel2:#15192a;--line:#283049;--text:#f6f7fb;--muted:#9da6bd;--green:#43d17f;--red:#ff5964;--orange:#ffb84d;--blue:#61a5ff;--purple:#a78bfa;}
    *{box-sizing:border-box}
    body{margin:0;background:radial-gradient(circle at top left,#22264a 0,#090b14 34%,#05060b 100%);color:var(--text);font-family:Inter,Segoe UI,Arial,sans-serif;overflow:hidden}
    .app{display:grid;grid-template-columns:260px 1fr;height:100vh}
    .sidebar{background:rgba(8,10,18,.82);backdrop-filter:blur(16px);border-right:1px solid var(--line);padding:22px;display:flex;flex-direction:column;gap:20px}
    .brand{display:flex;align-items:center;gap:12px}
    .logo{width:52px;height:44px;background:var(--yellow);display:grid;place-items:center;color:#e4002b;font-weight:800;font-size:18px}
    .brand h1{font-size:15px;line-height:1.2;margin:0}
    .brand p{margin:4px 0 0;color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.1em}
    .nav{display:flex;flex-direction:column;gap:8px}
    .nav button{background:transparent;color:#c5cce0;border:1px solid transparent;border-radius:14px;text-align:left;padding:12px 14px;font-weight:650;cursor:pointer}
    .nav button.active,.nav button:hover{background:linear-gradient(90deg,rgba(255,223,0,.18),rgba(97,165,255,.06));border-color:rgba(255,223,0,.35);color:white}
    .sidebarFooter{margin-top:auto;color:var(--muted);font-size:11px;line-height:1.55}
    .main{height:100vh;overflow:auto;padding:22px}
    .topbar{display:flex;justify-content:space-between;gap:16px;align-items:flex-start;margin-bottom:18px}
    .title h2{font-size:30px;margin:0;letter-spacing:-.04em}
    .title p{margin:6px 0 0;color:var(--muted)}
    .pill{display:inline-flex;align-items:center;gap:8px;border:1px solid rgba(255,223,0,.45);background:rgba(255,223,0,.08);color:var(--yellow);padding:7px 10px;border-radius:999px;font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.08em}
    .grid4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:14px}
    .grid3{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
    .card{background:linear-gradient(180deg,rgba(21,25,42,.94),rgba(13,16,28,.94));border:1px solid var(--line);border-radius:22px;padding:18px;box-shadow:0 20px 55px rgba(0,0,0,.28)}
    .metric .label{color:var(--muted);font-size:12px;text-transform:uppercase;letter-spacing:.09em}
    .metric .value{font-size:31px;font-weight:850;letter-spacing:-.05em;margin-top:8px}
    .metric .sub{font-size:13px;color:#b7bfd4;margin-top:4px}
    .spark{height:5px;background:#1f263b;border-radius:6px;margin-top:14px;overflow:hidden}
    .spark span{display:block;height:100%;background:linear-gradient(90deg,var(--yellow),#fff4a6);border-radius:6px}
    .layout{display:grid;grid-template-columns:1.05fr .95fr;gap:14px;margin-top:14px}
    .section{display:none}
    .section.active{display:block}
    .sectionTitle{font-size:18px;margin:0 0 12px}
    .filters{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:12px}
    .filters input,.filters select{background:#0b0e19;color:white;border:1px solid var(--line);border-radius:12px;padding:10px 12px;outline:none}
    .filters input:focus,.filters select:focus{border-color:var(--yellow);box-shadow:0 0 0 3px rgba(255,223,0,.1)}
    table{width:100%;border-collapse:separate;border-spacing:0 8px;font-size:12px}
    thead th{color:var(--muted);text-align:left;font-size:11px;text-transform:uppercase;letter-spacing:.08em;padding:0 10px;cursor:pointer}
    tbody tr{background:#111625}
    td{padding:11px 10px;border-top:1px solid #202942;border-bottom:1px solid #202942;vertical-align:top}
    td:first-child{border-left:1px solid #202942;border-radius:12px 0 0 12px;font-weight:800}
    td:last-child{border-right:1px solid #202942;border-radius:0 12px 12px 0}
    .num{text-align:right}
    .tag{border-radius:999px;padding:4px 8px;font-size:11px;font-weight:800;background:#202942;color:#dce3f8}
    .tag.high{background:rgba(255,89,100,.18);color:#ff99a0}
    .tag.medium{background:rgba(255,184,77,.18);color:#ffd194}
    .tag.watch{background:rgba(97,165,255,.18);color:#bcd9ff}
    .deltaPos{color:#8ef0b7;font-weight:800}
    .deltaNeg{color:#ffb4bb;font-weight:800}
    .mapWrap{height:calc(100vh - 170px);min-height:560px;border-radius:24px;overflow:hidden;border:1px solid var(--line);position:relative;background:#121622}
    .map{height:100%;width:100%}
    .mapPanel{position:absolute;top:14px;left:14px;z-index:500;background:rgba(9,11,20,.86);border:1px solid var(--line);border-radius:18px;padding:12px;width:340px;backdrop-filter:blur(12px)}
    .mapPanel h3{margin:0 0 8px}
    .mapPanel .filters{margin:0}
    .profile{position:absolute;right:14px;top:14px;bottom:14px;width:380px;z-index:501;background:rgba(10,12,22,.92);border:1px solid var(--line);border-radius:22px;padding:18px;backdrop-filter:blur(14px);overflow:auto;display:none}
    .profile.show{display:block}
    .close{float:right;background:#1c2235;border:1px solid var(--line);color:white;border-radius:10px;padding:6px 9px;cursor:pointer}
    .chart{height:260px;display:flex;align-items:end;gap:10px;padding:16px 8px 4px;border-top:1px solid var(--line);margin-top:8px;overflow-x:auto}
    .bar{flex:1;background:linear-gradient(180deg,var(--yellow),rgba(255,223,0,.22));border-radius:9px 9px 3px 3px;position:relative;min-width:22px}
    .bar em{position:absolute;bottom:100%;left:50%;transform:translateX(-50%);font-size:10px;color:#d7dce9;white-space:nowrap;margin-bottom:5px}
    .bar small{position:absolute;top:100%;left:50%;transform:translateX(-50%) rotate(-35deg);font-size:10px;color:var(--muted);white-space:nowrap;transform-origin:top left;margin-top:8px}
    .aiCards{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
    .aiCards h3{margin:0 0 8px}
    .aiCards p{color:#c5cce0;line-height:1.45}
    .kvs{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:12px}
    .kv{background:#0b0f1c;border:1px solid var(--line);border-radius:14px;padding:10px}
    .kv b{display:block;font-size:18px}
    .kv span{color:var(--muted);font-size:11px;text-transform:uppercase}
    .row{display:flex;gap:10px;align-items:center;justify-content:space-between}
    .btn{background:var(--yellow);border:0;border-radius:12px;color:#101010;font-weight:850;padding:10px 13px;cursor:pointer}
    .btn.secondary{background:#171d2e;color:white;border:1px solid var(--line)}
    .btn.ghost{background:transparent;border:1px solid rgba(255,223,0,.35);color:#fff}
    .btn.small{padding:8px 10px;font-size:12px}
    .insight{padding:13px;border:1px solid var(--line);background:#0b0f1c;border-radius:16px;margin-top:10px;color:#cfd6e9;line-height:1.45}
    .searchNote{color:var(--muted);font-size:12px;margin:5px 0 0}
    .tableWrap{max-height:calc(100vh - 240px);overflow:auto;padding-right:4px}
    .cardsList{display:grid;gap:10px;max-height:calc(100vh - 260px);overflow:auto}
    .miniCard{background:#0b0f1c;border:1px solid var(--line);border-radius:16px;padding:13px;cursor:pointer}
    .miniCard:hover{border-color:rgba(255,223,0,.45)}
    .miniCard h4{margin:0 0 6px}
    .miniCard p{margin:0;color:var(--muted);font-size:12px;line-height:1.4}
    .badge{color:var(--yellow);font-weight:900}
    .footerNote{font-size:11px;color:var(--muted);margin-top:12px;line-height:1.5}
    .reportGrid,.marketBreakdowns{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
    .subtle{color:var(--muted)}
    .reportButtons{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px}
    .trendWrap{margin-top:10px;border-top:1px solid var(--line);padding-top:10px}
    .trendTable{width:100%;border-collapse:collapse;font-size:11px}
    .trendTable th,.trendTable td{padding:7px 8px;border-bottom:1px solid #202942;text-align:right}
    .trendTable th:first-child,.trendTable td:first-child{text-align:left}
    .pillRow{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px}
    .pillStat{display:inline-flex;align-items:center;gap:6px;padding:7px 10px;border:1px solid var(--line);border-radius:999px;background:#0b0f1c;font-size:12px;color:#dce3f8}
    .pillStat b{color:var(--yellow)}
    .viewerHelp{font-size:12px;color:var(--muted);margin-top:6px}
    .modal{position:fixed;inset:0;background:rgba(2,4,10,.78);backdrop-filter:blur(8px);display:none;align-items:center;justify-content:center;z-index:3000;padding:20px}
    .modal.show{display:flex}
    .modalContent{width:min(1200px,96vw);height:min(88vh,980px);background:#0c101a;border:1px solid var(--line);border-radius:24px;box-shadow:0 25px 70px rgba(0,0,0,.45);display:flex;flex-direction:column;overflow:hidden}
    .modalHead{display:flex;justify-content:space-between;align-items:center;padding:14px 16px;border-bottom:1px solid var(--line)}
    .modalHead h3{margin:0;font-size:18px}
    .modalFrame{flex:1;background:#0a0d16}
    .modalFrame iframe{width:100%;height:100%;border:0;background:white}
    @media(max-width:1300px){.reportGrid,.marketBreakdowns,.aiCards,.grid3{grid-template-columns:1fr}}
    @media(max-width:1100px){.app{grid-template-columns:1fr}.sidebar{position:sticky;top:0;z-index:999;display:block}.nav{flex-direction:row;overflow:auto}.main{height:auto;overflow:visible}.grid4,.layout,.aiCards,.grid3,.reportGrid,.marketBreakdowns{grid-template-columns:1fr}.mapWrap{height:650px}.profile{left:14px;width:auto}.topbar{display:block}body{overflow:auto}}
  </style>
</head>
<body>
<div class="app">
  <aside class="sidebar">
    <div class="brand"><div class="logo">savills</div><div><h1>Industrial Market Intelligence & BD Dashboard</h1><p>PHL · PAC · NNJ</p></div></div>
    <div class="nav" id="nav"></div>
    <div class="sidebarFooter"><b>Fresh build</b><br>Building-first architecture. Clean comp data, active availability, expanded lease-event views, embedded Savills Research market reports, and better apples-to-apples concession analytics.</div>
  </aside>
  <main class="main">
    <div class="topbar"><div class="title"><span class="pill">Industrial Advisory</span><h2>PHL-PAC-NNJ Market Command Center</h2><p>Live intelligence layer for lease events, comps, availabilities, tenant leverage, and market-by-market comp analytics.</p></div><button class="btn secondary" onclick="downloadCSV()">Export Current Table</button></div>
    <section id="overview" class="section active"></section>
    <section id="map" class="section"></section>
    <section id="comps" class="section"></section>
    <section id="avail" class="section"></section>
    <section id="lease" class="section"></section>
    <section id="ai" class="section"></section>
    <section id="qa" class="section"></section>
  </main>
</div>
<div id="reportModal" class="modal">
  <div class="modalContent">
    <div class="modalHead">
      <h3 id="reportModalTitle">Market report</h3>
      <div class="row"><button class="btn ghost small" id="reportNewTab" target="_blank">Open in new tab</button><button class="close" onclick="closeReport()">×</button></div>
    </div>
    <div class="modalFrame"><iframe id="reportFrame" src=""></iframe></div>
  </div>
</div>
